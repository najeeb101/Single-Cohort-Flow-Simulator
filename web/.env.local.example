# Copy to .env.local and adjust if the API runs somewhere other than the documented
# `py -m uvicorn src.api:app --port 8001` (repo root). Falls back to this default if unset.
# Used both by next.config.ts's rewrite (browser calls -> this URL, server-to-server) and
# by the auth route handlers (web/src/app/api/auth/*) that proxy login/register directly.
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8001
